<%layout('layouts/boilerplate')%>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-3">
            <h3> <%= Listing.title %></h3>
            </div>
       
    <div class="card col-md-6 offset-md-3 show-card">
         <img src="<%= Listing.image.url %>" class="card-img-top show-img" alt="listing_image">
  <div class="card-body">
    <p class="card-text">&#8377; <%= Listing.price.toLocaleString("en-IN") %> /night</p>
    <p class="card-text"><%= Listing.description %></p>
    <p class="card-text"><%= Listing.location %></p>
    <p class="card-text"><%= Listing.country %></p>
  </div>
    </div>
    
    <br>
   
    </div>
     <div class="btns">
        <a href="/listings/<%= Listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>
    
    <form method="post" action="/listings/<%= Listing._id %>?_method=DELETE">
        <button type="submit" class="btn btn-dark  offset-5">Delete</button>
    </form>
    </div>

<div class="col-8 offset-3">
    <h4>leave a review</h4>
    <form>
        <div class="mb-3 mt-3">
            <label for="review" class="form-label">Review:</label>
           <input type="range" min="1" max="5" id="review" name="review[rating] " class="form-range">
        </div>
        <div class="mb-3 mt-3">
            <label for="comment" class="form-label">Comment:</label>
            <textarea id="comment" name="review[comment]" cols="30" rows="5" class="form-control"></textarea>
        </div>
        <button type="submit" class="btn btn-outline-dark">Submit</button>
    </form>
</div>